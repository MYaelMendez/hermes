{
  "name": "hermes-agent",
  "version": "1.0.0",
  "description": "An AI agent with advanced tool-calling capabilities, featuring a flexible toolsets system for organizing and managing tools.",
  "private": true,
  "scripts": {
    "glocal:git": "python scripts/glocal_git_status.py",
    "glocal:context": "python scripts/glocal_context_map.py",
    "glocal:verify": "python scripts/verify_submission_integrity.py",
    "coremode": "python scripts/coremode.py",
