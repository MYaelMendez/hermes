  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5a5a5a", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": { "foreground": "#6bffce" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#f0d066" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"],
      "settings": { "foreground": "#D4AF37" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#9a9a9a" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call.generic"],
      "settings": { "foreground": "#00ffa3" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#f0d066", "fontStyle": "" }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "support.variable"],
      "settings": { "foreground": "#e6e6e6" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#c8c8c8" }
    },
    {
      "scope": ["variable.language", "variable.language.this"],
      "settings": { "foreground": "#D4AF37", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#D4AF37" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#00ffa3", "fontStyle": "italic" }
    },
    {
      "scope": ["support.type.property-name", "meta.object-literal.key"],
      "settings": { "foreground": "#D4AF37" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#D4AF37", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#f0d066", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#6bffce" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#9a9a9a" }
    }
  ],
  "semanticTokenColors": {
    "function": "#00ffa3",
    "method": "#00ffa3",
    "class": "#f0d066",
    "type": "#f0d066",
    "keyword": "#D4AF37",
    "variable": "#e6e6e6",
    "parameter": "#c8c8c8",
    "property": "#D4AF37",
    "string": "#6bffce",
    "number": "#f0d066",
    "comment": "#5a5a5a"
  }
}
